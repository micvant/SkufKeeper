generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id                   String                  @id @default(cuid())
  email                String                  @unique
  passwordHash         String
  appTheme             String                  @default("emerald")
  appColorScheme       String                  @default("system")
  onboardingCompleted  Boolean                 @default(true)
  createdAt            DateTime                @default(now())
  updatedAt            DateTime                @updatedAt
  locations            StorageLocation[]
  items                Item[]
  customFieldDefinitions CustomFieldDefinition[]
  locationFavorites    LocationFavorite[]
  itemMoveLogs         ItemMoveLog[]
}

model CustomFieldDefinition {
  id         String             @id @default(cuid())
  userId     String
  user       User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  entityType String
  label      String
  fieldType  String             @default("text")
  options    String?
  sortOrder  Int                @default(0)
  createdAt  DateTime           @default(now())
  values     CustomFieldValue[]

  @@unique([userId, entityType, label])
  @@index([userId, entityType])
}

model CustomFieldValue {
  id           String                @id @default(cuid())
  definitionId String
  definition   CustomFieldDefinition @relation(fields: [definitionId], references: [id], onDelete: Cascade)
  itemId       String?
  item         Item?                 @relation(fields: [itemId], references: [id], onDelete: Cascade)
  locationId   String?
  location     StorageLocation?      @relation(fields: [locationId], references: [id], onDelete: Cascade)
  value        String
  createdAt    DateTime              @default(now())
  updatedAt    DateTime              @updatedAt

  @@unique([definitionId, itemId])
  @@unique([definitionId, locationId])
  @@index([itemId])
  @@index([locationId])
}

model StorageLocation {
  id          String             @id @default(cuid())
  qrToken     String             @unique
  userId      String?
  name        String
  description String?
  photoPath   String?
  iconName    String?
  color       String?
  parentId    String?
  parent      StorageLocation?   @relation("LocationTree", fields: [parentId], references: [id], onDelete: Cascade)
  children    StorageLocation[]  @relation("LocationTree")
  createdAt   DateTime           @default(now())
  updatedAt   DateTime           @updatedAt
  items       Item[]
  user        User?              @relation(fields: [userId], references: [id], onDelete: Cascade)
  customFields CustomFieldValue[]
  favorites   LocationFavorite[]

  @@index([userId])
  @@index([parentId])
}

model LocationFavorite {
  id         String          @id @default(cuid())
  userId     String
  user       User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  locationId String
  location   StorageLocation @relation(fields: [locationId], references: [id], onDelete: Cascade)
  sortOrder  Int             @default(0)
  createdAt  DateTime        @default(now())

  @@unique([userId, locationId])
  @@index([userId])
}

model Item {
  id           String             @id @default(cuid())
  userId       String?
  name         String
  description  String?
  photoPath    String?
  iconName     String?
  quantity     Float              @default(1)
  unit         String             @default("pcs")
  minQuantity  Float?
  expiresAt    DateTime?
  locationId   String
  location     StorageLocation    @relation(fields: [locationId], references: [id], onDelete: Cascade)
  createdAt    DateTime           @default(now())
  updatedAt    DateTime           @updatedAt
  user         User?              @relation(fields: [userId], references: [id], onDelete: Cascade)
  customFields CustomFieldValue[]
  moveLogs     ItemMoveLog[]

  @@index([userId])
  @@index([name])
  @@index([locationId])
  @@index([expiresAt])
}

model ItemMoveLog {
  id               String   @id @default(cuid())
  userId           String
  user             User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  itemId           String
  item             Item     @relation(fields: [itemId], references: [id], onDelete: Cascade)
  fromLocationId   String?
  fromLocationName String?
  toLocationId     String
  toLocationName   String
  comment          String?
  createdAt        DateTime @default(now())

  @@index([userId, createdAt])
  @@index([itemId])
}
