generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model StorageLocation {
  id          String   @id @default(cuid())
  qrToken     String   @unique
  name        String
  description String?
  photoPath   String?
  iconName    String?
  parentId    String?
  parent      StorageLocation?  @relation("LocationTree", fields: [parentId], references: [id], onDelete: Cascade)
  children    StorageLocation[] @relation("LocationTree")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  items       Item[]

  @@index([parentId])
}

model Item {
  id          String   @id @default(cuid())
  name        String
  description String?
  photoPath   String?
  iconName    String?
  quantity    Int      @default(1)
  locationId  String
  location    StorageLocation @relation(fields: [locationId], references: [id], onDelete: Cascade)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([name])
  @@index([locationId])
}
