# Local development
DATABASE_URL="file:./prisma/dev.db"
NEXT_PUBLIC_APP_URL="http://192.168.1.100:3000"

# Распознавание предметов по фото (приоритет: Yandex, затем Gemini)
# AI_PROVIDER="yandex"   # yandex | gemini | auto (по умолчанию auto)

# Yandex Cloud / AI Studio (доступно в РФ) — модель gemma-3-27b-it для картинок
# https://console.cloud.yandex.ru/ → каталог → API-ключ + ID каталога (folder_id)
# YANDEX_API_KEY=""
# YANDEX_FOLDER_ID=""
# YANDEX_VISION_MODEL="qwen3.6-35b-a3b/latest"

# Google Gemini (если доступен в вашем регионе)
# https://aistudio.google.com/apikey
# GEMINI_API_KEY=""
# GEMINI_MODEL="gemini-2.0-flash"

# Railway production (set in Railway Variables)
# DATABASE_URL="file:/data/dev.db"
# UPLOAD_DIR="/data/uploads"
# NEXT_PUBLIC_APP_URL="https://skufkeeper-production.up.railway.app"
# Volume mount path: /data
